    "@connexis/transport-sse": "workspace:*",
    "@connexis/transport-websocket": "workspace:*"
  },
  "devDependencies": {
    "@types/eventsource": "^3.0.0",
    "eventsource": "^4.1.0",
    "typescript": "^5.5.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarpalSingh7395/connexis.git"
