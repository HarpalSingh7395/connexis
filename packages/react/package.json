{
  "name": "@connexis/react",
  "version": "1.0.0",
  "description": "React hooks and provider for @connexis",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@connexis/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "typescript": "^5.5.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarpalSingh7395/connexis.git"
  },
  "keywords": [
    "realtime",
    "connection-manager",
    "react",
    "hooks",
    "websocket",
    "sse",
    "typescript"
  ],
  "author": "HarpalSingh7395 <harrysinghharpal58@gmail.com>",
  "license": "MIT",
  "homepage": "https://HarpalSingh7395.github.io/connexis/"
}
